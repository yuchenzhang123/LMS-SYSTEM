# 测试环境配置
NODE_ENV=production
VUE_APP_ENV=test
VUE_APP_ENABLE_SSO_GUARD=true
VUE_APP_API_PREFIX=/api
VUE_APP_SSO_PREFIX=/ssoservice
VUE_APP_API_BASE_URL=http://localhost:8099
VUE_APP_SSO_API_URL=http://smc-desktop.hi.bank-of-china.com:8098
VUE_APP_API_TARGET=http://localhost:8099
VUE_APP_SSO_TARGET=http://smc-desktop.hi.bank-of-china.com:8098
VUE_APP_SSO_LOGIN_URL=http://smc-desktop.hi.bank-of-china.com:8092/sso/?from=
VUE_APP_COOKIE_DOMAIN=.hi.bank-of-china.com
# Cookie名称：登录后实际设置的Cookie key
VUE_APP_COOKIE_NAME=SSOToken
VUE_APP_TITLE=LMS系统 - 测试环境
# 禁用登录跳转，用于调试Cookie验证问题（设置为true时不会跳转登录页）
# VUE_APP_DISABLE_LOGIN_REDIRECT=true

